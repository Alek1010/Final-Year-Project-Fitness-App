<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <EditText
            android:id="@+id/etCustomProgramName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Program name" />

        <EditText
            android:id="@+id/etDay1Name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Day 1 name"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/etDay1Exercises"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Day 1 exercises (comma separated)"
            android:minLines="3"
            android:gravity="top" />

        <EditText
            android:id="@+id/etDay2Name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Day 2 name"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/etDay2Exercises"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Day 2 exercises (comma separated)"
            android:minLines="3"
            android:gravity="top" />

        <EditText
            android:id="@+id/etDay3Name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Day 3 name (optional)"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/etDay3Exercises"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Day 3 exercises (comma separated)"
            android:minLines="3"
            android:gravity="top" />

    </LinearLayout>
</ScrollView>