<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Weight Progress"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvCurrentWeight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Current weight: -"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvRate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rate: -"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvGoalWeight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Goal weight: -"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etDurationWeeks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter duration (weeks)"
            android:inputType="number"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnSetGoal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calculate Goal Weight"
            android:layout_marginBottom="20dp" />

        <EditText
            android:id="@+id/etWeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter weight (kg)"
            android:inputType="numberDecimal"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnAddWeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Weight"
            android:layout_marginBottom="16dp" />

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/weightChart"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#EEEEEE"
            android:padding="16dp"
            android:text="" />
    </LinearLayout>
</ScrollView>