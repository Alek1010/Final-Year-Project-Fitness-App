<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set up your profile"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter your stats and choose how to set your targets."
            android:layout_marginBottom="20dp" />

        <!-- Body stats -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Body stats"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etBodyWeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Body weight (kg)"
            android:inputType="numberDecimal"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etHeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Height (cm)"
            android:inputType="number"
            android:layout_marginBottom="20dp" />

        <!-- Target setup method -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Target setup"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/rgTargetMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/rbManual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manual"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rbAuto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Automatic"
                android:layout_marginStart="16dp" />
        </RadioGroup>

        <!-- MANUAL SECTION -->
        <LinearLayout
            android:id="@+id/layoutManual"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manual daily targets"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:hint="Calories calculated"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />
            <TextView
                android:id="@+id/tvCalculatedCalories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0 kcal"
                android:background="#EEEEEE"
                android:padding="16dp"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/etTargetProtein"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Protein (g)"
                android:inputType="number"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etTargetCarbs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Carbs (g)"
                android:inputType="number"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etTargetFats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Fats (g)"
                android:inputType="number"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etTargetWater"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Water (L)"
                android:inputType="numberDecimal"
                android:layout_marginBottom="20dp" />
        </LinearLayout>

        <!-- AUTOMATIC SECTION -->
        <LinearLayout
            android:id="@+id/layoutAuto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Automatic goal"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <RadioGroup
                android:id="@+id/rgGoal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <RadioButton
                    android:id="@+id/rbMaintain"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Maintain weight" />

                <RadioButton
                    android:id="@+id/rbGain"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gain weight" />

                <RadioButton
                    android:id="@+id/rbLose"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lose weight" />
            </RadioGroup>

            <!-- Only show if Gain or Lose selected -->
            <LinearLayout
                android:id="@+id/layoutRate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Choose rate"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/rgRate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rbMild"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mild (0.25 kg/week)" />

                    <RadioButton
                        android:id="@+id/rbStandard"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Standard (0.5 kg/week)" />

                    <RadioButton
                        android:id="@+id/rbExtreme"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Extreme (1.0 kg/week)" />
                </RadioGroup>
            </LinearLayout>

            <!-- Placeholder preview text (for UI only) -->
            <TextView
                android:id="@+id/tvAutoPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Automatic targets will be calculated when you finish."
                android:background="#EEEEEE"
                android:padding="16dp"
                android:layout_marginBottom="20dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnFinishSetup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Finish setup" />

        <TextView
            android:id="@+id/tvSkip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Skip for now"
            android:textStyle="bold"
            android:layout_marginTop="14dp"
            android:clickable="true" />

    </LinearLayout>
</ScrollView>